# Copiar a `.env` en la raíz del proyecto si quieres personalizar (no subir `.env` al repo).

# URL del ai-service para el renderer (Vite) cuando exista cliente IA en la UI.
# VITE_AI_SERVICE_URL=http://127.0.0.1:8100

# URL que usa el proceso principal de Electron para comprobar /health antes de auto-arrancar.
# AI_SERVICE_URL=http://127.0.0.1:8100

# Raíz del monorepo D:\services\ (en Windows por defecto se usa D:\services si no se define).
# SERVICES_ROOT=D:\services

# Poner a 0 / false para no lanzar ai-service al abrir Carta Astral.
# AUTO_START_AI_SERVICE=1
